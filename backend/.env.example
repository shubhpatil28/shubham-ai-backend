# Shubham AI - Configuration Environment Variables

# OpenAI API Key for Chat completion, intent recognition, audio transcription, and webpage generation.
OPENAI_API_KEY=your_openai_api_key_here

# ElevenLabs API Key for high quality voice responses. If empty, local speech synthesis is used.
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Port for backend API
PORT=5000
